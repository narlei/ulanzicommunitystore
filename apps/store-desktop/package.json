{
  "name": "@ulanzideck/store-desktop",
  "productName": "Ulanzi Community Store",
  "version": "1.2.0",
  "description": "The open-source community store for Ulanzi Deck and Dial plugins",
  "private": true,
  "type": "module",
  "main": "dist/main/main.js",
  "author": "Narlei Moreira",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/narlei/ulanzicommunitystore.git"
  },
  "scripts": {
    "dev": "npm run build && node ../../scripts/brand-electron-app.mjs && electron .",
    "open": "node ../../scripts/brand-electron-app.mjs && electron .",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win"
  },
  "dependencies": {
    "@ulanzideck/catalog": "0.1.0",
    "adm-zip": "^0.5.16",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "43.0.0",
    "electron-builder": "^26.15.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "vite": "^6.0.3"
  },
  "build": {
    "appId": "com.narlei.ulanzicommunitystore",
    "productName": "Ulanzi Community Store",
    "directories": {
      "output": "release"
    },
    "icon": "build/icon.png",
    "files": [
      "dist/**",
      "build/icon.png",
      "package.json"
    ],
    "protocols": [
      {
        "name": "Ulanzi Community Store",
        "schemes": [
          "ulanzicommunitystore"
        ]
      }
    ],
    "afterPack": "scripts/afterPack.cjs",
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.utilities",
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "artifactName": "UlanziPluginStore-mac.${ext}"
    },
    "dmg": {
      "artifactName": "UlanziPluginStore.${ext}",
      "background": "build/dmg-background.png",
      "window": {
        "width": 660,
        "height": 420
      },
      "contents": [
        {
          "x": 180,
          "y": 260,
          "type": "file"
        },
        {
          "x": 480,
          "y": 260,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "artifactName": "UlanziPluginStore.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "narlei",
        "repo": "ulanzicommunitystore"
      }
    ]
  }
}
