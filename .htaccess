# A raiz do repo é o document root (Hostinger sincroniza o repo inteiro em public_html).
DirectoryIndex index.php

# Não listar diretórios
Options -Indexes

# Esconde arquivos/pastas de desenvolvimento que ficam no mesmo webroot.
# (registry/, assets/ e catalog.json continuam acessíveis — o site precisa deles.)
RedirectMatch 404 /\.git(/|$)
RedirectMatch 404 /\.github(/|$)
RedirectMatch 404 /\.claude(/|$)
RedirectMatch 404 ^/helper(/|$)
RedirectMatch 404 ^/scripts(/|$)
RedirectMatch 404 ^/Makefile$
RedirectMatch 404 ^/README\.md$
RedirectMatch 404 ^/\.gitignore$
RedirectMatch 404 ^/\.htaccess$
